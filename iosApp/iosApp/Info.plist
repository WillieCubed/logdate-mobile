<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>LogDate needs access to your photo library to show recent photos in the editor and attach them to your entries.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>LogDate saves shared images and exported postcards to your photo library when you ask it to.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>LogDate uses the microphone to record audio notes you can attach to entries.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>LogDate transcribes your audio notes on-device so you can search and read them as text.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>LogDate tags entries with your current location and shows where moments happened on your timeline.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>LogDate uses location in the background to build your location timeline so you can see where you were on a given day.</string>
	<key>NSCalendarsUsageDescription</key>
	<string>LogDate reads events from your calendars to add context and reminders to your timeline.</string>
	<key>NSCalendarsFullAccessUsageDescription</key>
	<string>LogDate reads events from your calendars to add context and reminders to your timeline.</string>
	<key>NSMotionUsageDescription</key>
	<string>LogDate uses motion sensors to enrich entries with activity context.</string>
	<key>NSContactsUsageDescription</key>
	<string>LogDate can read your contacts to suggest people to tag in entries.</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>instagram</string>
		<string>instagram-stories</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>app.logdate.sync.refresh</string>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>fetch</string>
		<string>location</string>
		<string>processing</string>
		<string>remote-notification</string>
	</array>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
