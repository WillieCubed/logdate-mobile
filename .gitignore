*.iml
.kotlin
.gradle
**/build/
xcuserdata
!src/**/build/
local.properties
.idea
.DS_Store
captures
.externalNativeBuild
.cxx
*.xcodeproj/*
!*.xcodeproj/project.pbxproj
!*.xcodeproj/xcshareddata/
!*.xcodeproj/project.xcworkspace/
!*.xcworkspace/contents.xcworkspacedata
**/xcshareddata/WorkspaceSettings.xcsettings

# Terraform
**/.terraform/
**/*.tfstate
**/*.tfstate.*
**/*.tfvars
!infra/terraform/*.tfvars
# Plan files embed the resolved value of every variable, including any
# secrets threaded in via -var=… — never commit them.
**/*.tfplan
# Developer-only env files for the deploy script. production.env carries real
# DATABASE_URL / OIDC / Redis credentials; it must stay out of git even if
# someone force-adds or renames it.
**/production.env
**/*.env.production
**/*.env.secrets

**/.claude/settings.local.json
**/.claude/scheduled_tasks.lock
**/.claude/worktrees/

# Per-platform Xcode build outputs (not the main Debug-iphoneos one tracked above)
iosApp/build-sim/

# Generated by scripts/resolve-ios-app-version.sh on every CI run.
# MARKETING_VERSION + CURRENT_PROJECT_VERSION are derived deterministically
# from the SHA + ios-v* tag; committing the snapshot would just create churn.
iosApp/Configuration/Version.xcconfig

# Python bytecode cache (created by py_compile / running .py scripts).
__pycache__/
*.pyc

# Local debug dumps and scratch state
tmp/

# Firebase local config
**/google-services.json
**/GoogleService-Info*.plist

# Turnkey deployment state
.logdate/
