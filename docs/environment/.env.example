# Environment variable template (copy to `.env` and do NOT commit)
# ============================================================================
# Local Development
# ============================================================================
OPENAI_API_KEY=replace-with-openai-key
DATABASE_URL=jdbc:postgresql://localhost:15432/logdate
REDIS_URL=redis://localhost:16379

# Optional: used by mobile builds if you source the env
GOOGLE_MAPS_API_KEY=replace-with-google-maps-key
META_APP_ID=replace-with-meta-app-id

# ============================================================================
# GCP Deployment (used by scripts/setup-gcp-deploy.sh)
# ============================================================================
# Required: Your GCP project ID (auto-detected from gcloud config if not set)
# GCP_PROJECT_ID=your-gcp-project-id

# Region for Cloud Run and Artifact Registry
GCP_REGION=us-central1

# Cloud Run service configuration
CLOUD_RUN_SERVICE_NAME=logdate-server
CLOUD_RUN_DOMAIN=cloud.logdate.app

# Artifact Registry repository name
ARTIFACT_REGISTRY_REPO=logdate

# GitHub repository (auto-detected from git remote if not set)
# GITHUB_REPO=owner/repo

# ============================================================================
# Production Secrets (set in GitHub Actions, not here)
# ============================================================================
# These are listed for reference - configure them in GitHub Secrets:
# - GCP_PROJECT_ID
# - GCP_WORKLOAD_IDENTITY_PROVIDER (output from setup script)
# - GCP_SERVICE_ACCOUNT (output from setup script)
# - DATABASE_URL
# - DATABASE_USER
# - DATABASE_PASSWORD
# - JWT_SECRET
# - GCS_BUCKET_NAME
# - GCS_MEDIA_KMS_KEY (optional)
# - MEDIA_ENCRYPTION_KEY (base64-encoded 16/24/32-byte key)
# - SYNC_MEDIA_SIGNED_URLS (true/false)
# - SYNC_MEDIA_SIGNED_URL_TTL_HOURS (1-24)
# - REDIS_URL
