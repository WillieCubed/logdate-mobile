<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Location permissions for personal location logging -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <uses-feature
        android:name="android.hardware.location.gps"
        android:required="false" />

    <application>
        <service
            android:name=".tracking.DetailedLocationTrackingService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="location" />

        <receiver
            android:name=".tracking.OptimizedBackgroundLocationReceiver"
            android:enabled="true"
            android:exported="false" />

        <receiver
            android:name=".tracking.LocationTrackingBootReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- Activity-aware location tracking foreground service -->
        <service
            android:name=".tracking.ActivityAwareLocationService"
            android:foregroundServiceType="location"
            android:exported="false" />

        <!-- Receives activity transition events (STILL, WALKING, IN_VEHICLE) from Google Play Services -->
        <receiver
            android:name=".tracking.ActivityTransitionReceiver"
            android:exported="false" />
    </application>

</manifest>
