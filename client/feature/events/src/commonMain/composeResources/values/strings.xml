<resources>
    <!-- Events hub (settings entry that gathers everything event-related) -->
    <string name="events_hub_title">Events</string>
    <string name="events_hub_description">LogDate quietly notices the things that happen to you — places you spent time, photos you took, plans on your calendar — and groups them into events so it&apos;s easier to look back, reflect, and see how your days connect.</string>
    <string name="events_hub_master_toggle">Notice events for me</string>
    <string name="events_hub_smart_names_title">Smart names</string>
    <string name="events_hub_smart_names_on">Each new event gets a short, descriptive title.</string>
    <string name="events_hub_smart_names_off">Events use a simple time-and-place label.</string>
    <string name="events_hub_calendar_row_title">Browse calendar</string>
    <string name="events_hub_calendar_row_subtitle">See your events on a month grid.</string>
    <string name="events_hub_sync_row_title">Your calendars</string>
    <string name="events_hub_sync_row_subtitle">Keep the things you already plan in the same place as everything else.</string>

    <!-- Calendar sync overview -->
    <string name="calendar_sync_settings_title">Your calendars</string>
    <string name="calendar_sync_settings_description">The plans you keep on your calendar are part of the picture. Bring them into LogDate so they sit alongside everything else, making it easier to look back on what your days were really about.</string>
    <string name="calendar_sync_settings_master_toggle">Use my calendars in LogDate</string>
    <string name="calendar_sync_settings_grant_title">Let LogDate read your calendars</string>
    <string name="calendar_sync_settings_grant_rationale">LogDate reads your calendars so it can help you remember what&apos;s coming up. Nothing leaves your device, and LogDate never writes back to the calendars themselves.</string>
    <string name="calendar_sync_settings_grant_action">Allow access</string>
    <string name="calendar_sync_settings_calendars_row_title">Calendars</string>
    <string name="calendar_sync_settings_calendars_row_subtitle_some">%1$d of %2$d selected</string>
    <string name="calendar_sync_settings_calendars_row_subtitle_none">Choose which ones to keep</string>
    <string name="calendar_sync_settings_activity_row_title">Imported events</string>
    <string name="calendar_sync_settings_activity_row_subtitle">See the events that came from your calendars.</string>

    <!-- Choose calendars -->
    <string name="calendar_sync_calendars_title">Choose calendars</string>
    <string name="calendar_sync_calendars_empty">No calendars found on this device.</string>
    <string name="calendar_sync_calendars_default_label">Default calendar</string>

    <!-- Recent imports -->
    <string name="calendar_sync_activity_title">Imported events</string>
    <string name="calendar_sync_activity_empty">Nothing imported yet. The next sync will pull events from the calendars you selected.</string>

