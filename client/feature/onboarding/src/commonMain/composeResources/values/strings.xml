    <string name="onboarding_location_title">Your places, your timeline</string>
    <string name="onboarding_location_body">LogDate can remember the places that matter to you \u2014 the coffee shop where you had that great conversation, the park where you watched the sunset. Build a timeline of everywhere you&apos;ve been.</string>
    <string name="onboarding_location_card_title">Location Timeline</string>
