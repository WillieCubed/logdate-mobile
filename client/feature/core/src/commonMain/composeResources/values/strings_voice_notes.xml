    <string name="voice_notes_settings_description">On-device transcription and ambient sound detection</string>

    <string name="voice_notes_settings_intro">Voice notes work without anything extra. Download these on-device models if you want sharper transcripts and the soundscape each note was captured in — everything stays on your device.</string>

    <string name="voice_notes_model_transcription_title">Sharper transcripts</string>
    <string name="voice_notes_model_transcription_description">Rewrites your spoken notes after recording with proper punctuation and casing.</string>

    <string name="voice_notes_model_tagging_title">Soundscape detection</string>
    <string name="voice_notes_model_tagging_description">Tags ambient sounds — birds, traffic, music, rain — alongside each voice note.</string>

