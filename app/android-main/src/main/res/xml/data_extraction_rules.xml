<?xml version="1.0" encoding="utf-8"?>
<!--
   Backup/restore rules for Android 12+ (API 31+).
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes

   Cloud backup (Google Drive, 25 MB limit):
     Includes the encrypted database and the recoverable passphrase backup so
     small databases survive cloud restore. Android silently drops files that
     push the total over 25 MB, so large databases will be skipped gracefully.
     EncryptedSharedPreferences are excluded (KeyStore-bound, useless after restore).

   Device-to-device transfer (direct local transfer, 2 GB limit):
     Transfers everything so the app works on the new device with zero friction.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="file" path="datastore/"/>
        <include domain="file" path="db_recovery/"/>
        <include domain="database" path="."/>
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="."/>
        <include domain="database" path="."/>
        <include domain="sharedpref" path="."/>
    </device-transfer>
</data-extraction-rules>
