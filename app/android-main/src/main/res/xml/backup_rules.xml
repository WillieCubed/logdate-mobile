<?xml version="1.0" encoding="utf-8"?>
<!--
   Backup rules for pre-API 31 devices.
   See https://developer.android.com/guide/topics/data/autobackup

   Cloud backup: DataStore preferences, passphrase backup, and the encrypted
   database (all require clientSideEncryption so they're encrypted in the cloud).
   Device-to-device: everything.
   Audio notes are excluded from both since they can be large.
-->
<full-backup-content>
    <include domain="file" path="datastore/"
             requireFlags="clientSideEncryption"/>
    <include domain="file" path="db_recovery/"
             requireFlags="clientSideEncryption"/>
    <include domain="database" path="."
             requireFlags="clientSideEncryption"/>
    <include domain="file" path="."
             requireFlags="deviceToDeviceTransfer"/>
    <include domain="database" path="."
             requireFlags="deviceToDeviceTransfer"/>
    <include domain="sharedpref" path="."
             requireFlags="deviceToDeviceTransfer"/>
    <exclude domain="file" path="audio_notes/"/>
</full-backup-content>
