<?xml version="1.0" encoding="utf-8"?>
<!--
  Static launcher shortcut + share-target declaration.

  Three things live here:

   1. The always-on "new note" launcher shortcut — fallback when no dynamic
      shortcuts are published yet (cold install, post-restore, etc.). It uses
      the existing AMBIENT_PROMPT_TARGET extras that MainActivity.resolveNavKey
      already understands.

   2. <share-target> entries that tell the system which dynamic shortcut
      categories can receive which mime types from the share sheet. The runtime
      sharing shortcuts are published per-journal by DynamicShortcutPublisher /
      AndroidDynamicShortcutApplier and tagged with the
      android.shortcut.conversation category — combined with these
      <share-target> declarations, the OS surfaces them as Direct Share
      targets in the system share sheet for any text/plain, image, or video
      share. The mime types here must match the existing <intent-filter>s on
      MainActivity.

   3. Stateful launcher shortcuts (continue draft, today's timeline, last
      week's rewind) are published dynamically — not declared here.

  Note: Assistant App Actions / capability bindings (CREATE_THING etc.) will
  return as App Functions (androidx.appfunctions) in a later tier — they were
  removed from this file because the legacy bindings pointed at a class that
  doesn't exist in this build and had no parameter handling either.
-->
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <shortcut
        android:enabled="true"
        android:icon="@drawable/note_stack_add"
        android:shortcutDisabledMessage="@string/shortcut_label_new_note_disabled"
        android:shortcutId="new_note"
        android:shortcutLongLabel="@string/shortcut_label_new_note_long"
        android:shortcutShortLabel="@string/shortcut_label_new_note_short">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetClass="app.logdate.client.MainActivity"
            android:targetPackage="co.reasonabletech.logdate">
            <extra
                android:name="ambient_prompt_target"
                android:value="new_entry" />
        </intent>
    </shortcut>

    <share-target android:targetClass="app.logdate.client.MainActivity">
        <data android:mimeType="text/plain" />
        <data android:mimeType="image/*" />
        <data android:mimeType="video/*" />
        <category android:name="android.shortcut.conversation" />
    </share-target>
</shortcuts>
