<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-feature android:name="android.hardware.type.watch" />

    <!-- Permissions required for audio recording on Wear OS -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!--
        Wear inherits ACCESS_FINE_LOCATION / ACCESS_COARSE_LOCATION from
        :client:location for on-demand geotagging at journal-entry save time.
        The watch flow does not run a foreground tracking service, register
        boot or activity-transition receivers, or sample location in the
        background, so opt out of those merged permissions to keep the Play
        Store sensitive-permissions surface aligned with the actual feature.
    -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" tools:node="remove" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" tools:node="remove" />
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" tools:node="remove" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" tools:node="remove" />

    <!-- Remove OpenGL ES requirement merged from Google Maps SDK -->
    <uses-feature android:glEsVersion="0x00020000" tools:node="remove" />

    <!-- Remove Google Maps package query merged from client:location -->
    <queries>
        <package android:name="com.google.android.apps.maps" tools:node="remove" />
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.DeviceDefault"
        android:name=".LogDateWearApplication">

        <!--
            Remove auto-initializers merged from transitive dependencies.
            Google Maps and Emoji2 are not used on Wear OS
            but their ContentProviders run before Application.onCreate(), adding
            500-1500ms of startup latency on constrained Wear hardware.
        -->

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <!-- Remove Emoji2 font download -->
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- Audio Recording Service -->
        <service
            android:name=".recording.WearAudioRecordingService"
            android:foregroundServiceType="microphone"
            android:enabled="true"
            android:exported="false" />

        <!-- Audio Playback Service — reused from client:media for voice note playback -->
        <service
            android:name="app.logdate.client.media.audio.AudioPlaybackService"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
            </intent-filter>
        </service>

        <!-- Data Layer sync listener: receives notes, journals, and associations from paired phone -->
        <service
            android:name=".sync.WearDataLayerListenerService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <data
                    android:scheme="wear"
                    android:host="*"
                    android:pathPrefix="/logdate/notes" />
                <data
                    android:scheme="wear"
                    android:host="*"
                    android:pathPrefix="/logdate/journals" />
                <data
                    android:scheme="wear"
                    android:host="*"
                    android:pathPrefix="/logdate/associations" />
            </intent-filter>
        </service>
            
        <!-- Entry Count complication: shows today's journal entry count -->
        <service
            android:name=".complication.EntryCountComplicationService"
            android:exported="true"
            android:label="@string/wear_complication_entry_count_label"
            android:permission="com.google.android.wearable.permission.BIND_COMPLICATION_PROVIDER">
            <intent-filter>
                <action android:name="android.support.wearable.complications.ACTION_COMPLICATION_UPDATE_REQUEST" />
            </intent-filter>

            <meta-data
                android:name="android.support.wearable.complications.SUPPORTED_TYPES"
                android:value="SHORT_TEXT" />
            <meta-data
                android:name="android.support.wearable.complications.UPDATE_PERIOD_SECONDS"
                android:value="900" />
        </service>

        <!-- Mood complication: shows today's mood emoji -->
        <service
            android:name=".complication.MoodComplicationService"
            android:exported="true"
            android:label="@string/wear_complication_mood_label"
            android:permission="com.google.android.wearable.permission.BIND_COMPLICATION_PROVIDER">
            <intent-filter>
                <action android:name="android.support.wearable.complications.ACTION_COMPLICATION_UPDATE_REQUEST" />
            </intent-filter>

            <meta-data
                android:name="android.support.wearable.complications.SUPPORTED_TYPES"
                android:value="SHORT_TEXT" />
            <meta-data
                android:name="android.support.wearable.complications.UPDATE_PERIOD_SECONDS"
                android:value="900" />
        </service>

        <!-- Streak complication: shows consecutive journaling day count -->
        <service
            android:name=".complication.StreakComplicationService"
            android:exported="true"
            android:label="@string/wear_complication_streak_label"
            android:permission="com.google.android.wearable.permission.BIND_COMPLICATION_PROVIDER">
            <intent-filter>
                <action android:name="android.support.wearable.complications.ACTION_COMPLICATION_UPDATE_REQUEST" />
            </intent-filter>

            <meta-data
                android:name="android.support.wearable.complications.SUPPORTED_TYPES"
                android:value="SHORT_TEXT,LONG_TEXT" />
            <meta-data
                android:name="android.support.wearable.complications.UPDATE_PERIOD_SECONDS"
                android:value="21600" />
        </service>

        <!-- Quick Capture complication: mic icon to start voice recording -->
        <service
            android:name=".complication.QuickCaptureComplicationService"
            android:exported="true"
            android:label="@string/wear_complication_quick_capture_label"
            android:permission="com.google.android.wearable.permission.BIND_COMPLICATION_PROVIDER">
            <intent-filter>
                <action android:name="android.support.wearable.complications.ACTION_COMPLICATION_UPDATE_REQUEST" />
            </intent-filter>

            <meta-data
                android:name="android.support.wearable.complications.SUPPORTED_TYPES"
                android:value="SMALL_IMAGE" />
            <meta-data
                android:name="android.support.wearable.complications.UPDATE_PERIOD_SECONDS"
                android:value="0" />
        </service>

        <!-- Quick Capture tile: four capture buttons + entry count -->
        <service
            android:name=".tile.QuickCaptureTileService"
            android:exported="true"
            android:label="@string/wear_tile_quick_capture_label"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>

            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@drawable/tile_preview" />
        </service>

        <!-- Today's Summary tile: entry count, mood, latest entry -->
        <service
            android:name=".tile.TodaySummaryTileService"
            android:exported="true"
            android:label="@string/wear_tile_summary_label"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>

            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@drawable/tile_preview" />
        </service>

        <!-- Journal prompt alarm receiver -->
        <receiver
            android:name=".notification.WearPromptReceiver"
            android:exported="false" />

        <!--
               Set to true if your app is Standalone, that is, it does not require the handheld
               app to run.
        -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="true" />

        <activity
            android:name=".presentation.MainActivity"
            android:exported="true"
            android:taskAffinity=""
            android:theme="@style/MainActivityTheme.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
