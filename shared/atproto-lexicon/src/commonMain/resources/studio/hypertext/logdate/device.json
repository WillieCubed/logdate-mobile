{
  "lexicon": 1,
  "id": "studio.hypertext.logdate.device",
  "defs": {
    "main": {
      "type": "object",
      "required": ["deviceId", "platform", "createdAt", "lastSeenAt"],
      "properties": {
        "deviceId": { "type": "string" },
        "platform": { "type": "string" },
        "deviceName": { "type": "string" },
        "osVersion": { "type": "string" },
        "appVersion": { "type": "string" },
        "capabilities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "integer" },
        "lastSeenAt": { "type": "integer" }
      }
    }
  }
}
