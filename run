#!/usr/bin/env bash
# run - Interactive entrypoint for LogDate development
#
# Usage:
#   ./run              # Interactive menu
#   ./run <command>    # Direct command execution
#   ./run help         # Show all commands

set -euo pipefail
cd "$(dirname "${BASH_SOURCE[0]}")"

# Source environment
[[ -f "docs/environment/.env.example" ]] && { set -a; source "docs/environment/.env.example"; set +a; }
[[ -f ".env" ]] && { set -a; source ".env"; set +a; }

# ============================================================================
# Command Registry (single source of truth)
# Format: category|command|description|shell_command
# ============================================================================

COMMANDS='
dev|dev:start|Start PostgreSQL, Redis, and dev tools|./scripts/dev-start.sh
dev|dev:stop|Stop all development services|./scripts/dev-stop.sh
dev|dev:status|Show status of dev services|./scripts/dev-status.sh
dev|dev:reset|Reset dev environment (deletes data)|./scripts/dev-reset.sh
dev|dev:logs|Follow logs from dev services|./scripts/dev-logs.sh

build|build:android|Build Android debug APK|./gradlew :app:android-main:assembleDebug
build|build:android:release|Build Android release APK|./gradlew :app:android-main:assembleRelease
build|build:desktop|Build desktop app for current OS|./gradlew :app:compose-main:packageDistributionForCurrentOS
build|build:wear|Build Wear OS debug APK|./gradlew :app:wear:assembleDebug
build|build:server|Build server JAR|./gradlew :server:build
build|build:server:docker|Build server Docker image locally|docker build --target production -t logdate-server:local .
build|build:all|Build all modules|./gradlew build

run|run:android|Install and run on connected Android device|./gradlew :app:android-main:installDebug
run|run:desktop|Run desktop app|./gradlew :app:compose-main:run
run|run:server|Run server locally|./gradlew :server:run
run|run:wear|Install and run on connected Wear device|./gradlew :app:wear:installDebug

test|test|Run all unit tests|./gradlew test
test|test:android|Run Android unit tests|./gradlew :app:android-main:testDebugUnitTest
test|test:server|Run server tests|./gradlew :server:test
test|test:coverage|Generate test coverage report|./gradlew koverHtmlReport
test|test:verify|Verify coverage meets threshold|./gradlew koverVerify
test|test:bench:phone|Run managed phone macrobenchmarks|./gradlew managedPhoneBenchmark
test|test:bench:wear|Run managed Wear OS macrobenchmarks|./gradlew managedWearBenchmark
test|test:bench:micro|Run Android microbenchmarks|./gradlew managedMicroBenchmark
test|test:screenshots|Validate screenshot tests|./gradlew :app:android-main:validateDebugScreenshotTest
test|test:screenshots:update|Regenerate golden screenshots|./gradlew :app:android-main:updateDebugScreenshotTest

quality|lint|Run Android lint|./gradlew lint
quality|lint:check|Check Kotlin code style|./gradlew ktlintCheck
quality|lint:format|Auto-format Kotlin code|./gradlew ktlintFormat
quality|lint:modules|Verify ktlint task coverage for all modules|./scripts/verify-ktlint-task-coverage.sh
quality|check|Run all checks (tests + lint)|./gradlew check
quality|perf:baseline:phone|Generate phone baseline profile|./gradlew generatePhoneBaselineProfile
quality|perf:baseline:wear|Generate Wear baseline profile|./gradlew generateWearBaselineProfile

docs|docs|Generate API documentation|./gradlew dokkaHtmlMultiModule
docs|docs:open|Open generated documentation|open build/dokka/htmlMultiModule/index.html 2>/dev/null || xdg-open build/dokka/htmlMultiModule/index.html 2>/dev/null || echo "Open build/dokka/htmlMultiModule/index.html"
docs|docs:performance|Open performance documentation index|open docs/performance/README.md 2>/dev/null || xdg-open docs/performance/README.md 2>/dev/null || echo "Open docs/performance/README.md"

deploy|deploy:setup|One-time GCP infrastructure setup|./scripts/setup-gcp-deploy.sh
deploy|deploy:cloud-run|Deploy server to Cloud Run|./scripts/deploy-cloud-run.sh
deploy|deploy:bootstrap|Bootstrap a fresh GCP LogDate Cloud instance|./scripts/bootstrap-gcp-fresh.sh
deploy|deploy:production|One-shot production deploy (tfvars + terraform + secrets + image + DNS)|./scripts/deploy-production.sh

setup|setup:hooks|Configure git hooks for commit validation|./scripts/setup-hooks.sh

utils|clean|Clean all build outputs|./gradlew clean
utils|deps:update|Check for dependency updates|./gradlew dependencyUpdates
utils|deps:add|Add a Gradle dependency to the version catalog|./scripts/add-dep.sh
utils|gradle:stop|Stop Gradle daemon|./gradlew --stop
'

# Category display names
CATEGORY_NAMES='
dev|Development Environment
build|Build
run|Run
test|Testing
quality|Code Quality
docs|Documentation
deploy|Deployment
setup|Setup
utils|Utilities
'

# Shortcuts: shortcut|actual_command
SHORTCUTS='
start|dev:start
stop|dev:stop
status|dev:status
android|run:android
desktop|run:desktop
server|run:server
'

# ============================================================================
# Colors
# ============================================================================

R='\033[0;31m' G='\033[0;32m' Y='\033[1;33m' B='\033[0;34m' C='\033[0;36m'
BOLD='\033[1m' DIM='\033[2m' NC='\033[0m'

# ============================================================================
# Registry Lookups
# ============================================================================

get_command() {
    echo "$COMMANDS" | grep "^[^|]*|$1|" | cut -d'|' -f4 || true
}

get_description() {
    echo "$COMMANDS" | grep "^[^|]*|$1|" | cut -d'|' -f3 || true
}

get_category_name() {
    echo "$CATEGORY_NAMES" | grep "^$1|" | cut -d'|' -f2 || true
}

get_commands_in_category() {
    echo "$COMMANDS" | grep "^$1|" | cut -d'|' -f2 || true
}

resolve_shortcut() {
    echo "$SHORTCUTS" | grep "^$1|" | cut -d'|' -f2 || true
}

# ============================================================================
# UI
# ============================================================================

header() {
    echo ""
    echo -e "${BOLD}${B}╔══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}${B}║${NC}              ${BOLD}LogDate Development Console${NC}                   ${BOLD}${B}║${NC}"
    echo -e "${BOLD}${B}╚══════════════════════════════════════════════════════════════╝${NC}"
    echo ""
}

run_cmd() {
    local cmd="$1"
    local shell_cmd desc

    shell_cmd="$(get_command "$cmd")"
    if [[ -z "$shell_cmd" ]]; then
        echo -e "${R}Unknown command: $cmd${NC}"
        echo "Run './run help' to see available commands."
        exit 1
    fi

    desc="$(get_description "$cmd")"
    echo -e "${C}▶ ${desc}${NC}"
    echo -e "${DIM}  ${shell_cmd}${NC}"
    echo ""
    eval "$shell_cmd"
}

print_help() {
    echo -e "${BOLD}Usage:${NC}  ./run [command]"
    echo ""
    echo -e "${BOLD}Shortcuts:${NC}"
    echo "$SHORTCUTS" | while IFS='|' read -r shortcut actual; do
        [[ -z "$shortcut" ]] && continue
        printf "  ./run %-10s → %s\n" "$shortcut" "$actual"
    done
    echo ""
    echo -e "${BOLD}Commands:${NC}"

    for cat in dev build run test quality docs deploy utils; do
        local cat_name
        cat_name="$(get_category_name "$cat")"
        [[ -z "$cat_name" ]] && continue

        echo ""
        echo -e "${C}${cat_name}${NC}"
        get_commands_in_category "$cat" | while read -r cmd; do
            [[ -z "$cmd" ]] && continue
            printf "  ${G}%-22s${NC} %s\n" "$cmd" "$(get_description "$cmd")"
        done
    done
    echo ""
}

category_menu() {
    local cat="$1"
    local cat_name
    cat_name="$(get_category_name "$cat")"

    echo -e "${BOLD}${cat_name}${NC}"
    echo ""

    local i=1
    local cmds=()
    while read -r cmd; do
        [[ -z "$cmd" ]] && continue
        cmds+=("$cmd")
        printf "  ${G}%d)${NC} %-20s ${DIM}%s${NC}\n" "$i" "$cmd" "$(get_description "$cmd")"
        ((i++))
    done < <(get_commands_in_category "$cat")

    echo ""
    printf "  ${Y}0)${NC} ← Back\n"
    echo ""

    read -r -p "Select: " choice
    [[ "$choice" == "0" || -z "$choice" ]] && return

    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#cmds[@]} )); then
        echo ""
        run_cmd "${cmds[$((choice-1))]}"
    else
        echo -e "${R}Invalid selection${NC}"
    fi
}

main_menu() {
    header
    echo -e "${BOLD}What would you like to do?${NC}"
    echo ""

    local cats=(dev build run test quality docs deploy utils)
    local i=1
    for cat in "${cats[@]}"; do
        printf "  ${G}%d)${NC} %s\n" "$i" "$(get_category_name "$cat")"
        ((i++))
    done

    echo ""
    echo -e "  ${Y}h)${NC} Help    ${Y}q)${NC} Quit"
    echo ""

    read -r -p "Select: " choice

    case "$choice" in
        [1-8])
            echo ""
            category_menu "${cats[$((choice-1))]}"
            ;;
        q|Q) echo "Bye!"; exit 0 ;;
        h|H) echo ""; print_help ;;
        *)   echo -e "${R}Invalid selection${NC}" ;;
    esac
}

# ============================================================================
# Main
# ============================================================================

# Handle shortcuts
if [[ $# -gt 0 ]]; then
    resolved="$(resolve_shortcut "$1")"
    [[ -n "$resolved" ]] && { run_cmd "$resolved"; exit 0; }
fi

case "${1:-}" in
    "")
        while true; do
            main_menu
            echo ""
            read -r -p "Press Enter to continue..."
        done
        ;;
    help|--help|-h)
        header
        print_help
        ;;
    *)
        run_cmd "$1"
        ;;
esac
