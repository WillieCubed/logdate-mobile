#!/usr/bin/env bash
# commit-msg hook - Validates commit message format and scope rules.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
COMMIT_MSG_FILE="$1"

formatter_output="$("$REPO_ROOT/scripts/validation/format-commit-message.sh" "$COMMIT_MSG_FILE" 2>&1)"
if [[ -n "$formatter_output" ]]; then
    echo "$formatter_output"
fi

set +e
output="$("$REPO_ROOT/scripts/validation/validate-commit-message.sh" --file "$COMMIT_MSG_FILE" --context commit-msg 2>&1)"
status=$?
set -e

if [[ $status -ne 0 ]]; then
    echo ""
    echo "=========================================="
    echo "  COMMIT MESSAGE VALIDATION FAILED"
    echo "=========================================="
    echo ""
    if [[ -n "$output" ]]; then
        while IFS= read -r line; do
            [[ -n "$line" ]] && echo "  $line"
        done <<< "$output"
    fi
    echo ""
    echo "  See: docs/reference/standards/commit-messages.md"
    echo "=========================================="
    echo ""
    exit 1
fi

if [[ -n "$output" ]]; then
    echo "$output"
fi
