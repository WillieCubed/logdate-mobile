#!/usr/bin/env bash
# pre-commit hook - Validates staged files before committing
#
# Checks:
# 1. Sensitive file guard (reject secrets, keystores, credentials)
# 2. Sensitive content scan in staged additions
# 3. Kotlin lint via ktlint on affected modules

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"
source "$REPO_ROOT/scripts/validation/hook-common.sh"

errors=()

# Get list of staged files
staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"

if [[ -z "$staged_files" ]]; then
    exit 0
fi

# ============================================================================
# 1. Sensitive file guard
# ============================================================================

sensitive_patterns=(
    '\.env$'
    'local\.properties$'
    '\.keystore$'
    '\.jks$'
    'google-services\.json$'
    'credentials\.json$'
    'apikey'
    'secret'
    '\.pem$'
    '\.p12$'
)

sensitive_found=()
for pattern in "${sensitive_patterns[@]}"; do
    matches="$(echo "$staged_files" | grep -iE "$pattern" || true)"
    if [[ -n "$matches" ]]; then
        while IFS= read -r match; do
            sensitive_found+=("$match")
        done <<< "$matches"
    fi
done

if [[ ${#sensitive_found[@]} -gt 0 ]]; then
    sensitive_found_sorted="$(printf '%s\n' "${sensitive_found[@]}" | uniq_non_empty_lines)"
    sensitive_found=()
    while IFS= read -r f; do
        [[ -n "$f" ]] && sensitive_found+=("$f")
    done <<< "$sensitive_found_sorted"
fi

if [[ ${#sensitive_found[@]} -gt 0 ]]; then
    errors+=("SENSITIVE FILES: The following files may contain secrets and should not be committed:")
    for f in "${sensitive_found[@]}"; do
        errors+=("  - $f")
    done
    errors+=("  If intentional, add to .gitignore or use git update-index --assume-unchanged")
fi

# ============================================================================
# 2. Sensitive content scan in staged additions
# ============================================================================

secret_line_patterns=(
    'AKIA[0-9A-Z]{16}'
    '-----BEGIN (RSA|EC|DSA|OPENSSH|PGP) PRIVATE KEY-----'
    '(api[_-]?key|secret|token|password)[[:space:]]*[:=][[:space:]]*["'"'"'][^"'"'"']{8,}["'"'"']'
)

secret_hits=()
while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    if echo "$file" | grep -qE '(^|/)(package-lock\.json|yarn\.lock|pnpm-lock\.yaml|Cargo\.lock)$'; then
        continue
    fi

    added_lines="$(git diff --cached --no-color -U0 -- "$file" | grep -E '^\+[^+]' | sed 's/^+//' || true)"
    [[ -z "$added_lines" ]] && continue

    for pattern in "${secret_line_patterns[@]}"; do
        if echo "$added_lines" | grep -qiE -e "$pattern"; then
            secret_hits+=("$file")
            break
        fi
    done
done <<< "$staged_files"

if [[ ${#secret_hits[@]} -gt 0 ]]; then
    secret_hits_sorted="$(printf '%s\n' "${secret_hits[@]}" | uniq_non_empty_lines)"
    errors+=("SENSITIVE CONTENT: Potential secrets found in staged additions:")
    while IFS= read -r f; do
        [[ -n "$f" ]] && errors+=("  - $f")
    done <<< "$secret_hits_sorted"
fi

# ============================================================================
# 3. Kotlin lint (ktlint) on affected modules
# ============================================================================

# Collect Kotlin/KTS files
kt_files="$(echo "$staged_files" | grep -E '\.(kt|kts)$' || true)"

if [[ -n "$kt_files" ]]; then
    resolved_modules="$(modules_from_files "$kt_files")"
    modules=()
    while IFS= read -r module; do
        [[ -n "$module" ]] && modules+=("$module")
    done <<< "$resolved_modules"

    if [[ ${#modules[@]} -gt 0 ]]; then
        ktlint_tasks=()
        mod=""
        for mod in "${modules[@]}"; do
            ktlint_tasks+=("${mod}:ktlintFormat")
        done

        if [[ ${#ktlint_tasks[@]} -gt 0 ]]; then
            echo "Running ktlint on affected modules: ${modules[*]}"
            ./gradlew "${ktlint_tasks[@]}" --quiet 2>&1 || true
            # Re-stage files that ktlintFormat may have modified
            echo "$kt_files" | xargs git add
            # Verify no remaining lint violations after auto-fix
            ktlint_check_tasks=()
            for mod in "${modules[@]}"; do
                ktlint_check_tasks+=("${mod}:ktlintCheck")
            done
            if ! ./gradlew "${ktlint_check_tasks[@]}" --quiet 2>&1; then
                errors+=("KTLINT: Kotlin lint check failed even after auto-fix.")
                errors+=("  If a module is missing ktlintCheck, run: ./scripts/verify-ktlint-task-coverage.sh")
            fi
        fi
    fi
fi

if [[ ${#errors[@]} -gt 0 ]]; then
    print_error_report "PRE-COMMIT VALIDATION FAILED"
    exit 1
fi

exit 0
